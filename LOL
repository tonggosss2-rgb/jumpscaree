<!DOCTYPE html>
<html>
<head>
  <title>Loading...</title>
  <style>
    body {
      margin: 0;
      background: black;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      color: white;
      font-family: Arial;
    }

    #fake {
      font-size: 24px;
    }

    #scare {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: black;
    }

    #scare img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  </style>
</head>

<body>

<div id="fake">Loading... 0%</div>

<div id="scare">
  <img src="https://i.imgur.com/yourimage.png">
  <audio id="sound" src="https://www.myinstants.com/media/sounds/scream.mp3"></audio>
</div>

<script>
let percent = 0;
let fake = document.getElementById("fake");

let interval = setInterval(() => {
  percent += 5;
  fake.innerText = "Loading... " + percent + "%";

  if (percent >= 100) {
    clearInterval(interval);

    setTimeout(() => {
      document.getElementById("fake").style.display = "none";
      let scare = document.getElementById("scare");
      scare.style.display = "block";

      let sound = document.getElementById("sound");
      sound.play();
    }, 500);
  }
}, 200);
</script>

</body>
</html>
